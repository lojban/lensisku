{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "project": ["src/**/*.{ts,vue,js}"],
  "ignore": ["packages/ui/**"],
  "exclude": ["files", "dependencies", "devDependencies", "unlisted", "binaries", "unresolved"],
  "ignoreBinaries": ["preview"],
  "ignoreDependencies": [
    "@tailwindcss/typography",
    "mathjax",
    "@typescript-eslint/eslint-plugin",
    "@typescript-eslint/parser",
    "eslint-import-resolver-alias",
    "eslint-import-resolver-vite",
    "eslint-plugin-import",
    "eslint-plugin-vue",
    "husky",
    "lint-staged"
  ],
  "ignoreIssues": {
    "src/api.js": ["exports"],
    "src/composables/useAnonymousProgress.js": ["exports"],
    "src/config/lingoConstants.ts": ["exports"],
    "src/config/locales.ts": ["exports"],
    "src/utils/searchQueue.js": ["exports"],
    "src/router/index.ts": ["types"]
  }
}
