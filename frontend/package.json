{
  "name": "vue-ssg-i18n-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "typecheck:watch": "vue-tsc --noEmit -p tsconfig.app.json --watch",
    "typecheck:pretty": "vue-tsc --noEmit -p tsconfig.app.json --pretty",
    "build": "vue-tsc --noEmit -p tsconfig.app.json && vite-ssg build",
    "start": "vue-tsc --noEmit -p tsconfig.app.json && vite-ssg build && pnpm preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip --no-config-hints",
    "i18n:check": "node scripts/check-i18n-keys.mjs",
    "check": "pnpm run typecheck && pnpm run lint && pnpm knip && pnpm run i18n:check"
  },
  "dependencies": {
    "@milkdown/core": "^7.19.1",
    "@milkdown/crepe": "^7.19.1",
    "@milkdown/utils": "^7.19.1",
    "@paypal/paypal-js": "^8.2.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/vue-virtual": "^3.13.23",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vueuse/core": "^14.2.1",
    "@vueuse/head": "^2.0.0",
    "axios": "^1.13.6",
    "cytoscape": "^3.33.2",
    "cytoscape-fcose": "^2.2.0",
    "jwt-decode": "4.0.0",
    "lucide-vue-next": "^0.577.0",
    "marked": "^15.0.7",
    "mathjax": "^3.2.2",
    "socket.io-client": "^4.8.3",
    "turndown": "^7.2.2",
    "vite-ssg": "^28.3.0",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-vite": "^2.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-vue": "^9.33.0",
    "husky": "^9.1.7",
    "knip": "^6.0.2",
    "lint-staged": "^15.5.0",
    "postcss": "^8.5.8",
    "prettier": "^3.5.3",
    "prettier-plugin-vue": "^1.1.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vue-tsc": "^3.2.6"
  }
}
